# plymouth # FIXME: leads to crash when installed?
# plymouth-themes

# killall
psmisc

# xkill
x11-utils

# automounter; running 'devmon' will automount removable drives
udevil
sshfs

# Needed for Network prefPane
network-manager

# Needed for Audio prefPane
alsa-utils

# Sharing
avahi-daemon
openssh-server

# AppImages using an outdated runtime (e.g., Jitsi Meet desktop app)
libfuse2t64

qemu-guest-agent
